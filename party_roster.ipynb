   "source": [
    "party = [\n",
    "  ('Cloud',21,'Soldier'),\n",
    "  ('Tifa',20,'Monk'),\n",
    "  ('Barret',35,'Gunner')\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e4b6b81e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hello, I am Cloud, a 21 year old Soldier\n",
      "Hello, I am Tifa, a 20 year old Monk\n",
      "Hello, I am Barret, a 35 year old Gunner\n"
     ]
    }
   ],
   "source": [
    "for name,age,job in party:\n",
    "  print(\"Hello, I am {}, a {} year old {}\".format(name,age,job))"
   ]
